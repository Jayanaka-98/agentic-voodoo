"""Auto-lifted OSP+byLLM version of SKILL.md.

Generated by examples/lift_skill.jac. Review before use.
"""

import from tools { execute_python, bash, write_file, read_file };
import from os { };  # specify at least one item

obj InputData { has url: str; has file_path: str; };
obj SummaryResult { has summary: str; };
enum Stage { parse_input, summarize_content };

# Function to parse input
sem parse_input = "Parse the input data for further processing."
def parse_input(url: str, file_path: str) -> InputData by llm();

# Function to summarize content
sem summarize_content = "Generate a concise summary based on the parsed input."
def summarize_content(url: str, file_path: str) -> SummaryResult by llm();

# Function to fix code in case of errors
sem fix_jac_code = "Diagnose and correct errors in the Jac code."
def fix_jac_code(broken: str, error: str) -> str by llm();

node parse_input {
  can step_parse_input with InputData entry {
    let data = self.user_task;
    if data is None { return; }
    let parsed = parse_input(data.url, data.file_path);
    visit [-->];
  }
}

node summarize_content {
  can step_summarize_content with InputData entry {
    let data = self.user_task;
    if data is None { return; }
    let summary = summarize_content(data.url, data.file_path);
    visit [-->];
  }
}

node execute {
  can step_execute with SummaryResult entry {
    while not artifact_exists and attempts < 2 {
      fix_jac_code(...);
      execute_python(...);
    }
  }
}

with entry {
  root ++> parse_input ++> summarize_content ++> execute;
  spawn SummarizeAgent();
}

with entry {
  validate_output_artifacts();
  show_results();
}